# ── CryptoBot 單一實例 .env 範本（多人使用，每人一份）──
# 放到：/home/cryptobot/instances/<名字>/.env
# 這份是「該使用者」的專屬設定：自己的 Binance 帳號 + 自己的 Telegram bot。
# INSTANCE_DIR 由 systemd 帶入（cryptobot@.service），這裡不用寫。

# ── 顯示名（Telegram 每則訊息開頭會標「👤 名字」，讓你確認查到的是自己的）──
# 不填則自動用實例目錄名（如 instances/alice → alice）
INSTANCE_NAME=Alice

# ── 模式 ──
PAPER_TRADING=false          # true=模擬（寫 data/），false=正式真錢（寫 data_live/）
BINANCE_TESTNET=false        # true=Testnet，false=正式 API

# ── Binance（該使用者自己的 key；務必：只開交易權限、關提款、IP 白名單綁本 VPS）──
BINANCE_API_KEY=請填該使用者的_API_KEY
BINANCE_API_SECRET=請填該使用者的_API_SECRET

# ── Telegram（該使用者自己的 bot；多實例必須「每人一支 bot」，同 token 兩進程會搶更新）──
# 用 @BotFather 開一支新 bot 拿 token；chat_id 用 @userinfobot 或對 bot 說話後查 getUpdates
# TELEGRAM_CHAT_ID 支援「逗號分隔多值」：私聊 + 群組（群組 id 是負數）都會收到通知，
# 指令也只接受這些聊天室。例：TELEGRAM_CHAT_ID=123456789,-1001111111111
TELEGRAM_BOT_TOKEN=請填該使用者的_BOT_TOKEN
TELEGRAM_CHAT_ID=請填該使用者的_CHAT_ID

# ── 管理員白名單（選填）──
# 設定後，控制類指令（/pause /resume /cleanup）只有這些 Telegram user id 能用；
# 查詢類（/pnl /status /signal...）授權聊天室內任何人都可用。
# 不設 = 授權聊天室內任何人可用全部指令（單人私聊時無差別）。
# 群組使用時「強烈建議設定」，否則群裡任何成員都能暫停你的機器人。
# 自己的 user id 用 @userinfobot 查。多人用逗號分隔。
TELEGRAM_ADMIN_IDS=

# ── 部位大小（單一來源；改這裡 = 改實際下單名目 = MARGIN_PER_TRADE × LEVERAGE）──
SYMBOL=ETHUSDT
MARGIN_PER_TRADE=200
LEVERAGE=20
INITIAL_BALANCE=1000         # cumulative_pnl 基準（顯示用，非實際餘額）
COOLDOWN_SECONDS=60
